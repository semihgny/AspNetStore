@model IEnumerable<aspnet.Models.SupportTicket>

@{
    ViewData["Title"] = "Destek Talepleri";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">Destek Talepleri</h1>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> Henüz destek talebi bulunmamaktadır.
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Talep No</th>
                                <th>Kullanıcı</th>
                                <th>Konu</th>
                                <th>Durum</th>
                                <th>Oluşturulma Tarihi</th>
                                <th>Son Güncelleme</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ticket in Model)
                            {
                                <tr>
                                    <td>@ticket.TicketNumber</td>
                                    <td>@ticket.User?.FullName</td>
                                    <td>@ticket.Subject</td>
                                    <td>
                                        <span class="badge bg-@(ticket.Status switch {
                                            "Open" => "success",
                                            "Waiting" => "warning",
                                            "Answered" => "info",
                                            "Solved" => "primary",
                                            "Closed" => "secondary",
                                            _ => "primary"
                                        })">
                                            @ticket.Status
                                        </span>
                                    </td>
                                    <td>@ticket.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>@(ticket.LastUpdatedAt?.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                                    <td>
                                        <a asp-action="SupportTicketDetails" asp-route-id="@ticket.Id" 
                                           class="btn btn-primary btn-sm">
                                            <i class="bi bi-eye"></i> Görüntüle
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div> 