@model aspnet.Models.Order
@using aspnet.Models.Enums

@{
    ViewData["Title"] = $"Sipariş #{Model.OrderNumber}";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewData["Title"]</h2>
        <a asp-action="Orders" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Siparişlere Dön
        </a>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="card-title">Sipariş Detayları</h5>
                    <hr />
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Ürün</th>
                                    <th>Birim Fiyat</th>
                                    <th>Adet</th>
                                    <th class="text-end">Toplam</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.OrderDetails)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <img src="@item.Product.ImageUrl" alt="@item.Product.Name"
                                                     style="width: 50px; height: 50px; object-fit: cover;" class="me-2" />
                                                <span>@item.Product.Name</span>
                                            </div>
                                        </td>
                                        <td>@item.UnitPrice.ToString("C2")</td>
                                        <td>@item.Quantity</td>
                                        <td class="text-end">@((item.UnitPrice * item.Quantity).ToString("C2"))</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="3" class="text-end"><strong>Toplam Tutar:</strong></td>
                                    <td class="text-end"><strong>@Model.TotalAmount.ToString("C2")</strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="card-title">Müşteri Bilgileri</h5>
                    <hr />
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Ad Soyad</dt>
                        <dd class="col-sm-8">@Model.FirstName @Model.LastName</dd>

                        <dt class="col-sm-4">E-posta</dt>
                        <dd class="col-sm-8">@Model.Email</dd>

                        <dt class="col-sm-4">Telefon</dt>
                        <dd class="col-sm-8">@Model.Phone</dd>
                    </dl>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="card-title">Teslimat Bilgileri</h5>
                    <hr />
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Adres</dt>
                        <dd class="col-sm-8">@Model.Address</dd>

                        <dt class="col-sm-4">İlçe/İl</dt>
                        <dd class="col-sm-8">@Model.District / @Model.City</dd>

                        <dt class="col-sm-4">Posta Kodu</dt>
                        <dd class="col-sm-8">@Model.PostalCode</dd>
                    </dl>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Sipariş Durumu</h5>
                    <hr />
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Durum</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-@(Model.Status switch {
                                OrderStatus.Pending => "warning",
                                OrderStatus.Processing => "info",
                                OrderStatus.Shipped => "primary",
                                OrderStatus.Delivered => "success",
                                OrderStatus.Cancelled => "danger",
                                _ => "secondary"
                            })">@Model.Status</span>
                        </dd>

                        <dt class="col-sm-4">Ödeme</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-@(Model.PaymentStatus switch {
                                "Paid" => "success",
                                "Pending" => "warning",
                                "Failed" => "danger",
                                _ => "secondary"
                            })">@Model.PaymentStatus</span>
                        </dd>

                        <dt class="col-sm-4">Tarih</dt>
                        <dd class="col-sm-8">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</dd>
                    </dl>

                    <hr />

                    <form asp-action="UpdateOrderStatus" method="post" class="mt-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="mb-3">
                            <label class="form-label">Sipariş Durumunu Güncelle</label>
                            <select name="status" class="form-select" required>
                                <option value="@OrderStatus.Pending" selected="@(Model.Status == OrderStatus.Pending)">Beklemede</option>
                                <option value="@OrderStatus.Processing" selected="@(Model.Status == OrderStatus.Processing)">İşleniyor</option>
                                <option value="@OrderStatus.Shipped" selected="@(Model.Status == OrderStatus.Shipped)">Kargoda</option>
                                <option value="@OrderStatus.Delivered" selected="@(Model.Status == OrderStatus.Delivered)">Teslim Edildi</option>
                                <option value="@OrderStatus.Cancelled" selected="@(Model.Status == OrderStatus.Cancelled)">İptal Edildi</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Durumu Güncelle</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div> 