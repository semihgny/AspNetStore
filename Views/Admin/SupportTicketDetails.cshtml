@model aspnet.Models.SupportTicket

@{
    ViewData["Title"] = $"Destek Talebi - {Model.TicketNumber}";
}

<div class="container-fluid py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Yönetim Paneli</a></li>
            <li class="breadcrumb-item"><a asp-action="SupportTickets">Destek Talepleri</a></li>
            <li class="breadcrumb-item active">@Model.TicketNumber</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-4">
            <div class="card mb-4">
                <div class="card-body">
                    <h5 class="card-title">Talep Bilgileri</h5>
                    <hr>
                    <dl class="row">
                        <dt class="col-sm-4">Talep No</dt>
                        <dd class="col-sm-8">@Model.TicketNumber</dd>

                        <dt class="col-sm-4">Durum</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-@(Model.Status switch {
                                "Open" => "success",
                                "Waiting" => "warning",
                                "Answered" => "info",
                                "Closed" => "secondary",
                                _ => "primary"
                            })">@Model.Status</span>
                        </dd>

                        <dt class="col-sm-4">Kullanıcı</dt>
                        <dd class="col-sm-8">@Model.User?.FullName</dd>

                        <dt class="col-sm-4">E-posta</dt>
                        <dd class="col-sm-8">@Model.Email</dd>

                        <dt class="col-sm-4">Oluşturulma</dt>
                        <dd class="col-sm-8">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</dd>

                        <dt class="col-sm-4">Son Güncelleme</dt>
                        <dd class="col-sm-8">@(Model.LastUpdatedAt?.ToString("dd.MM.yyyy HH:mm") ?? "-")</dd>
                    </dl>

                    <hr>
                    <h6 class="mb-3">Durumu Güncelle</h6>
                    <div class="d-flex gap-2">
                        <form asp-action="UpdateTicketStatus" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ticketId" value="@Model.Id" />
                            <input type="hidden" name="status" value="Open" />
                            <button type="submit" class="btn btn-outline-success btn-sm" 
                                    @(Model.Status == "Open" ? "disabled" : "")>
                                <i class="bi bi-check-circle"></i> Açık
                            </button>
                        </form>

                        <form asp-action="UpdateTicketStatus" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ticketId" value="@Model.Id" />
                            <input type="hidden" name="status" value="Waiting" />
                            <button type="submit" class="btn btn-outline-warning btn-sm"
                                    @(Model.Status == "Waiting" ? "disabled" : "")>
                                <i class="bi bi-clock"></i> Beklemede
                            </button>
                        </form>

                        <form asp-action="UpdateTicketStatus" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ticketId" value="@Model.Id" />
                            <input type="hidden" name="status" value="Answered" />
                            <button type="submit" class="btn btn-outline-info btn-sm"
                                    @(Model.Status == "Answered" ? "disabled" : "")>
                                <i class="bi bi-reply"></i> Yanıtlandı
                            </button>
                        </form>

                        <form asp-action="UpdateTicketStatus" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ticketId" value="@Model.Id" />
                            <input type="hidden" name="status" value="Solved" />
                            <button type="submit" class="btn btn-outline-primary btn-sm"
                                    @(Model.Status == "Solved" ? "disabled" : "")>
                                <i class="bi bi-check2-all"></i> Çözüldü
                            </button>
                        </form>

                        <form asp-action="UpdateTicketStatus" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ticketId" value="@Model.Id" />
                            <input type="hidden" name="status" value="Closed" />
                            <button type="submit" class="btn btn-outline-secondary btn-sm"
                                    @(Model.Status == "Closed" ? "disabled" : "")>
                                <i class="bi bi-x-circle"></i> Kapatıldı
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">@Model.Subject</h5>
                    <hr>

                    <div class="messages">
                        @foreach (var message in Model.Messages.OrderBy(m => m.CreatedAt))
                        {
                            <div class="message @(message.IsStaffReply ? "staff-reply" : "user-message") mb-4">
                                <div class="message-header d-flex justify-content-between align-items-center mb-2">
                                    <strong>@(message.IsStaffReply ? "Destek Ekibi" : Model.User?.FullName)</strong>
                                    <small class="text-muted">@message.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
                                </div>
                                <div class="message-content p-3 rounded @(message.IsStaffReply ? "bg-light" : "bg-primary bg-opacity-10")">
                                    @message.Message
                                </div>
                            </div>
                        }
                    </div>

                    @if (Model.Status != "Closed")
                    {
                        <form asp-action="SupportTicketReply" method="post" class="mt-4">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ticketId" value="@Model.Id" />
                            
                            <div class="mb-3">
                                <label for="message" class="form-label">Yanıtınız</label>
                                <textarea name="message" id="message" class="form-control" rows="4" required></textarea>
                            </div>

                            <div class="d-flex justify-content-between align-items-center">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-send"></i> Yanıt Gönder
                                </button>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .message-content {
        white-space: pre-wrap;
    }
</style> 