@model aspnet.Models.Product

@{
    ViewData["Title"] = "Ürün Detayı";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="row g-0">
                    <div class="col-md-4">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" class="img-fluid rounded-start" alt="@Model.Name" style="height: 100%; object-fit: cover;">
                        }
                        else
                        {
                            <img src="/images/no-image.png" class="img-fluid rounded-start" alt="No Image" style="height: 100%; object-fit: cover;">
                        }
                    </div>
                    <div class="col-md-8">
                        <div class="card-body">
                            <h2 class="card-title">@Model.Name</h2>
                            <p class="card-text">@Model.Description</p>
                            <hr />
                            <div class="row mb-3">
                                <div class="col-6">
                                    <h5 class="text-primary mb-0">@Model.Price.ToString("C")</h5>
                                </div>
                                <div class="col-6 text-end">
                                    <span class="badge bg-info">Stok: @Model.StockQuantity</span>
                                </div>
                            </div>
                            <p class="card-text">
                                <small class="text-muted">Kategori: @Model.Category?.Name</small>
                            </p>
                            <p class="card-text">
                                <small class="text-muted">Durum: @(Model.IsActive ? "Aktif" : "Pasif")</small>
                            </p>
                            <p class="card-text">
                                <small class="text-muted">Oluşturulma Tarihi: @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                            </p>
                            @if (Model.UpdatedAt.HasValue)
                            {
                                <p class="card-text">
                                    <small class="text-muted">Son Güncelleme: @Model.UpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")</small>
                                </p>
                            }
                            
                            @if (Model.StockQuantity > 0)
                            {
                                <form id="addToCartForm" asp-controller="Cart" asp-action="AddToCart" method="post" class="mb-3">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@Model.Id" />
                                    <div class="input-group">
                                        <input type="number" name="quantity" id="quantity" value="1" min="1" max="@Model.StockQuantity" 
                                               class="form-control" style="max-width: 100px;" required />
                                        <button type="submit" class="btn btn-primary" id="addToCartBtn">
                                            <i class="bi bi-cart-plus"></i> Sepete Ekle
                                        </button>
                                    </div>
                                    <small class="text-muted">Maximum @Model.StockQuantity adet ekleyebilirsiniz</small>
                                </form>
                            }
                            else
                            {
                                <div class="alert alert-warning">
                                    <i class="bi bi-exclamation-triangle"></i> Bu ürün stokta yok.
                                </div>
                            }

                            <div class="mt-3">
                                <a asp-action="Index" class="btn btn-secondary">Listeye Dön</a>

                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>



@section Scripts {
    <script>
        document.getElementById('addToCartForm').addEventListener('submit', function(e) {
            var quantity = parseInt(document.getElementById('quantity').value);
            var maxStock = @Model.StockQuantity;
            
            if (quantity <= 0) {
                e.preventDefault();
                alert('Lütfen geçerli bir miktar girin.');
                return false;
            }
            
            if (quantity > maxStock) {
                e.preventDefault();
                alert('Stokta yeterli ürün yok. Maximum ' + maxStock + ' adet ekleyebilirsiniz.');
                return false;
            }
            
            // Form gönderilmeden önce butonu devre dışı bırak
            document.getElementById('addToCartBtn').disabled = true;
            document.getElementById('addToCartBtn').innerHTML = '<i class="bi bi-hourglass-split"></i> Ekleniyor...';
        });
    </script>
} 