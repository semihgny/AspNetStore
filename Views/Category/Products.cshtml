@model aspnet.Models.Category

@{
    ViewData["Title"] = $"{Model.Name} - Ürünler";
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Ana Sayfa</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Kategoriler</a></li>
            <li class="breadcrumb-item active">@Model.Name</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>@Model.Name - Ürünler</h1>

    </div>

    @if (!Model.Products.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> Bu kategoride henüz ürün bulunmamaktadır.
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var product in Model.Products.Where(p => p.IsActive))
            {
                <div class="col">
                    <div class="card h-100">
                        @if (!string.IsNullOrEmpty(product.ImageUrl))
                        {
                            <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name">
                        }
                        else
                        {
                            <img src="/images/no-image.png" class="card-img-top" alt="No Image">
                        }
                        <div class="card-body">
                            <h5 class="card-title">@product.Name</h5>
                            <p class="card-text text-truncate">@product.Description</p>
                            <p class="card-text">
                                <span class="price">@product.Price.ToString("C")</span>
                                <div class="card-footer bg-transparent border-top-0">
                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@product.Id" class="btn btn-info btn-sm w-100">Detaylar</a>
                                </div>
                            </p>
                        </div>
                        <div class="card-footer bg-transparent border-top-0">
                            <div class="d-flex justify-content-between align-items-center">

                                <form asp-controller="Product" asp-action="Delete" asp-route-id="@product.Id"
                                    >

                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div> 