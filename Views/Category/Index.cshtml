@model IEnumerable<aspnet.Models.Category>

@{
    ViewData["Title"] = "Kategoriler";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Kategoriler</h1>

    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100">
                    <div class="card-body position-relative">
                        <a asp-action="Products" asp-route-id="@item.Id" class="position-absolute top-0 end-0 m-2 text-decoration-none text-primary" title="Ürünleri Görüntüle">
                            <i class="bi bi-box-seam fs-4"></i>
                        </a>

                        <h5 class="card-title">@item.Name</h5>

                        <p class="card-text">
                            <small class="text-muted">Oluşturulma: @item.CreatedAt.ToString("dd.MM.yyyy")</small>
                        </p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
