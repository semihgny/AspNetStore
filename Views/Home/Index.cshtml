@model IEnumerable<aspnet.Models.Product>

@{
    ViewData["Title"] = "Ana Sayfa";
    var categories = ViewBag.Categories as List<aspnet.Models.Category>;
}

<div class="hero-section text-white py-5 mb-5">
    <div class="container rounded-4 p-0">
        <div class="rounded-4 p-5 text-white"
             style="background: url('/images/banner.jpg') no-repeat center center/cover;">
            <div class="bg-dark bg-opacity-50 rounded-4 p-4">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <h1 class="display-4 fw-bold">Hoş Geldiniz!</h1>
                        <p class="lead">En kaliteli ürünler, en uygun fiyatlarla sizlerle.</p>
                        <a href="#categories" class="btn btn-light btn-lg">Alışverişe Başla</a>
                    </div>
                    <div class="col-md-6 text-center d-none d-md-block">
                        <img src="/images/logo.png" alt="Shop" class="img-fluid" style="max-height: 300px;">
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container mb-5" id="categories">
    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">Henüz ürün bulunmamaktadır.</div>
    }
    else if (categories == null || !categories.Any())
    {
        <div class="alert alert-info">Henüz kategori bulunmamaktadır.</div>
    }
    else
    {
        @foreach (var category in categories.Where(c => c.Products != null && c.Products.Any()))
        {
            <div class="mb-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="fw-bold">@category.Name</h2>
                    <a asp-controller="Category" asp-action="Products" asp-route-id="@category.Id" class="btn btn-outline-primary">Tümünü Gör</a>
                </div>
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
                    @foreach (var product in Model.Where(p => p.CategoryId == category.Id && p.IsActive && p.Category != null && p.Category.IsActive).Take(4))
                    {
                        <div class="col">
                            <div class="card h-100 shadow-sm border-0">
                                <div style="height: 200px; overflow: hidden;">
                                    <img src="@(!string.IsNullOrEmpty(product.ImageUrl) ? product.ImageUrl : "/images/no-image.png")" class="w-100 h-100 object-fit-cover" alt="@product.Name">
                                </div>
                                <div class="card-body">
                                    <h5 class="card-title fw-semibold">@product.Name</h5>
                                    @if (!string.IsNullOrEmpty(product.Description))
                                    {
                                        <p class="card-text text-truncate small text-muted">@product.Description</p>
                                    }
                                    <p class="card-text"><small class="text-secondary">@(product.Category?.Name ?? "Kategori Yok")</small></p>
                                </div>
                                <div class="card-footer bg-transparent border-top-0">
                                    <span class="price fw-bold text-primary">@product.Price.ToString("C")</span>
                                    @if (product.StockQuantity > 0)
                                    {
                                        <form asp-controller="Cart" asp-action="AddToCart" method="post" class="mt-2">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="productId" value="@product.Id" />
                                            <button type="submit" class="btn btn-primary w-100">
                                                <i class="bi bi-cart-plus"></i> Sepete Ekle
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button class="btn btn-secondary w-100 mt-2" disabled>
                                            <i class="bi bi-x-circle"></i> Stokta Yok
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

<div class="container mb-5">
    <div class="row row-cols-1 row-cols-md-4 g-4">
        <div class="col">
            <div class="card h-100 text-center shadow-sm border-0">
                <div class="card-body py-4">
                    <i class="bi bi-truck fs-1 text-primary mb-3"></i>
                    <h5 class="card-title fw-semibold">Ücretsiz Kargo</h5>
                    <p class="card-text text-muted">250 TL ve üzeri alışverişlerinizde kargo ücretsiz!</p>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 text-center shadow-sm border-0">
                <div class="card-body py-4">
                    <i class="bi bi-shield-check fs-1 text-primary mb-3"></i>
                    <h5 class="card-title fw-semibold">Güvenli Ödeme</h5>
                    <p class="card-text text-muted">Kapıda ödeme seçeneği ile güvenli alışveriş</p>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 text-center shadow-sm border-0">
                <div class="card-body py-4">
                    <i class="bi bi-arrow-counterclockwise fs-1 text-primary mb-3"></i>
                    <h5 class="card-title fw-semibold">Kolay İade</h5>
                    <p class="card-text text-muted">14 gün içinde koşulsuz iade garantisi</p>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 text-center shadow-sm border-0">
                <div class="card-body py-4">
                    <i class="bi bi-headset fs-1 text-primary mb-3"></i>
                    <h5 class="card-title fw-semibold">7/24 Destek</h5>
                    <p class="card-text text-muted">Müşteri hizmetleri her zaman yanınızda</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('a[href^="#"]').on('click', function (e) {
                e.preventDefault();
                var target = $(this.hash);
                if (target.length) {
                    $('html, body').animate({ scrollTop: target.offset().top - 70 }, 1000);
                }
            });
        });
    </script>
}